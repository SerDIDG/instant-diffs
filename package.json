{
	"name": "instant-diffs",
	"version": "5.13.0+build.1",
	"description": "A JavaScript tool that enhances MediaWiki diff links with interactive functionality.",
	"keywords": [
		"wikipedia",
		"wikimedia",
		"mediawiki",
		"wiki",
		"gadget",
		"diff",
		"visual",
		"ajax",
		"javascript"
	],
	"homepage": "https://www.mediawiki.org/wiki/Instant_Diffs",
	"bugs": {
		"url": "https://github.com/SerDIDG/instant-diffs/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/SerDIDG/instant-diffs.git"
	},
	"license": "(MIT OR CC-BY-SA-4.0)",
	"author": {
		"name": "Serhio Magpie",
		"email": "serdidg@gmail.com",
		"url": "https://screensider.com"
	},
	"main": "src/app.js",
	"scripts": {
		"buildI18n": "node ./scripts/buildI18n.mjs",

		"start": "npm run buildI18n && node esbuild.config.mjs --start --dev",
		"start:local": "cross-env PROJECT=local npm run start",

		"dev": "npm run buildI18n && node esbuild.config.mjs --build --dev",
		"dev:testwiki": "cross-env PROJECT=testwiki npm run dev",
		"dev:mediawiki": "cross-env PROJECT=mediawiki npm run dev",

		"build": "npm run buildI18n && node esbuild.config.mjs --build",
		"build:testwiki": "cross-env PROJECT=testwiki npm run build",
		"build:mediawiki": "cross-env PROJECT=mediawiki npm run build",

		"deploy-dev": "npm run dev && node scripts/deploy.mjs --dev",
		"deploy-dev:testwiki": "cross-env PROJECT=testwiki npm run deploy-dev",
		"deploy-dev:mediawiki": "cross-env PROJECT=mediawiki npm run deploy-dev",

		"deploy": "npm run build && node scripts/deploy.mjs",
		"deploy:testwiki": "cross-env PROJECT=testwiki npm run deploy",
		"deploy:mediawiki": "cross-env PROJECT=mediawiki npm run deploy",

		"deploy-i18n": "npm run buildI18n && node scripts/deploy.mjs --i18n",
		"deploy-i18n:testwiki": "cross-env PROJECT=testwiki npm run deploy-i18n",
		"deploy-i18n:mediawiki": "cross-env PROJECT=mediawiki npm run deploy-i18n"
	},
	"engines": {
		"node": ">=21.2.0"
	},
	"devDependencies": {
		"@fal-works/esbuild-plugin-global-externals": "^2.1.2",
		"@types/oojs-ui": "^0.50.0",
		"@wikimedia/codex-design-tokens": "^2.6.0",
		"chalk": "^5.6.2",
		"cross-env": "^10.1.0",
		"dompurify": "^3.4.9",
		"esbuild": "0.28.1",
		"esbuild-plugin-copy": "^2.1.1",
		"esbuild-plugin-import-glob": "^0.1.1",
		"esbuild-plugin-less": "^1.3.38",
		"esbuild-plugin-replace": "^1.4.0",
		"eslint": "^10.4.1",
		"hyperscript": "^2.0.2",
		"jsdom": "^29.1.1",
		"minimist": "^1.2.8",
		"mwn": "^3.0.2",
		"prompts": "^2.4.2",
		"types-mediawiki": "^2.0.0"
	}
}
